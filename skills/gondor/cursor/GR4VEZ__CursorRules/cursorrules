{
    "description": "Cursor AI code generation rules with clear separation between local file logic and cross-file architecture patterns.",
    "version": "2.0",
    "rules": [
      {
        "pattern": "**/*.{js,ts,tsx}",
        "category": "local-file-rules",
        "priority": "high",
        "instructions": [
          "CATEGORY: Local File Rules",
          "PRIORITY: High",
          "DESCRIPTION: Strict rules for individual JavaScript and TypeScript files focusing on style, immutability, and declarative logic",
          "",
          "DEFAULT_VALUES:",
          "  RULE: Set defaults for arrays at declaration",
          "  PATTERN: const MyComponent = ({ myVar = [] }) => {…}",
          "  PATTERN: const myVar = … || []",
          "  RULE: Never set defaults for objects at declaration point, this enforces verbose checking at var usage",
          "  AVOID: const { myVar = {} } = temp || {}",
          "  PATTERN: const { myVar } = temp || {}; //const test = profile && myProfileHandler();",
          "  RULE: Only set defaults for objects when destructuring",
          "  PATTERN: const { myVar, myOtherVar } = temp || {}",
          "",
          "VARIABLES:",
          "  RULE: Use 'const' for all variable declarations",
          "  AVOID: 'let' or 'var' declarations",
          "  RULE: Never reassign variables declared with const",
          "  RULE: Create new constants instead of reassigning",
          "",
          "DESTRUCTURING:",
          "  RULE: Avoid dot syntax for deeply nested object properties",
          "  RULE: Use destructuring at the top of the scope",
          "  RULE: Check for undefined parent objects before destructuring",
          "  RULE: Always provide default empty objects for destructuring",
          "  EXAMPLE: const { value } = target || {}",
          "",
          "SAFETY_CHECKS:",
          "  RULE: Always check for variable existence before calling methods",
          "  PATTERN: variable && variable.method()",
          "  EXAMPLE: data && data.filter()",
          "  EXAMPLE: array && array.map()",
          "  AVOID: variable.method() without existence check",
          "  AVOID: data.filter()",
          "  AVOID: array.map()",
          "",
          "IMMUTABILITY:",
          "  RULE: Treat all objects as immutable",
          "  RULE: Use spread syntax for object/array updates",
          "  AVOID: Mutating existing objects or arrays",
          "",
          "FUNCTIONS:",
          "  RULE: Use arrow functions for all anonymous functions",
          "  RULE: Use map/filter/reduce for data transformation",
          "  AVOID: forEach for returning data structures",
          "  ALLOW: forEach only for side effects (logging, API calls)",
          "",
          "LOGIC:",
          "  RULE: Do not use ternary operators and if statements",
          "  RULE: Use chained declarative expressions",
          "  RULE: Use if statements for early returns only",
          "  EXAMPLE: const result = a && b || c && d || fallback",
          "  RULE: Break large functions into smaller ones",
          "  RULE: Never use optional chaining (?.) - use conditional checks instead",
          "  EXAMPLE: if (data && data[category]) instead of data?.[category]",
          "",
          "JSX_TEMPLATES:",
          "  RULE: Never declare or call functions inside JSX return blocks",
          "  RULE: Define all logic as constants above the return",
          "  EXCEPTION: Third-party libraries with clean dot-syntax (motion.div(), t.function())",
          "",
          "STYLE:",
          "  RULE: Use single quotes for all strings",
          "  ALLOW: Double quotes only when escaping requires it",
          "  RULE: Prefer named exports over default exports",
          "  RULE: Avoid unnecessary constants - call functions directly if used once",
          ""
        ]
      },
      {
        "pattern": "**/*.{js,ts,tsx}",
        "category": "architecture-rules", 
        "priority": "medium",
        "instructions": [
          "CATEGORY: Architecture Rules",
          "PRIORITY: Medium",
          "DESCRIPTION: Cross-file architectural patterns and shared logic organization",
          "",
          "SHARED_LOGIC:",
          "  RULE: Move constants used in multiple files to shared modules",
          "  EXAMPLES: src/constants/index.js, src/utils/index.js",
          "  RULE: Always use imports for repeated logic or values",
          "  AVOID: Copy-pasting or re-declaring the same constant",
          "",
          "MODULE_ORGANIZATION:",
          "  RULE: Create shared files only if reuse is guaranteed",
          "  RULE: Keep values local if not shared",
          "  RULE: Update all referencing files when relocating shared logic",
          "  RULE: Group related constants/utilities by domain",
          "  AVOID: Dumping everything into one file"
        ]
      }
    ]
  }
